                    ['Quarta', 'Descanso', '-', '-', 'Alongamento'],
                    ['Quinta', 'Tempo run', 'Ritmo limiar', `${Math.round(km*0.6)}km`, 'Confortavelmente difícil'],
                    ['Sexta', 'Corrida moderada', 'Ritmo constante', `${Math.round(km*0.5)}km`, ''],
                    ['Sábado', 'Corrida longa', 'Resistência', `${Math.round(km*0.8)}km`, 'Hidratação'],
                    ['Domingo', 'Descanso', '-', '-', 'Recuperação total']
