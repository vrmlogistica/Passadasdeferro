            const cabecalho = ['DIA', 'TIPO DE TREINO', 'DETALHES', 'VOLUME', 'OBSERVAÇÕES'];

            let linhas = [];
            if (modalidade === 'corrida') {
                const km = parseFloat(extra) || 10;
                linhas = [
