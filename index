                    ['Terça', 'Séries', 'Intervalado', '12x50m', 'Descanso 20s'],
                    ['Quarta', 'Descanso', '-', '-', 'Alongamento em seco'],
                    ['Quinta', 'Resistência', 'Nado contínuo', `${Math.round(metros*0.6)}m`, 'Ritmo moderado'],
                    ['Sexta', 'Velocidade', 'Séries curtas', '8x25m máx', 'Recuperação total'],
                    ['Sábado', 'Fundo', 'Nado longo', `${Math.round(metros*0.8)}m`, 'Controle de respiração'],
                    ['Domingo', 'Descanso', '-', '-', 'Recuperação']
                ];
            } else {
                linhas = [
                    ['Segunda', 'Peito/Tríceps', 'Supino, crucifixo, tríceps', '3x10-12', ''],
                    ['Terça', 'Costas/Bíceps', 'Puxada, remada, rosca', '3x10-12', ''],
                    ['Quarta', 'Pernas', 'Agachamento, leg press', '4x10', 'Fortalecimento'],
                    ['Quinta', 'Ombros/Abs', 'Desenvolvimento, elevação', '3x12', ''],
                    ['Sexta', 'Cardio + funcional', 'Circuito metabólico', '30 min', 'Queima calórica'],
                    ['Sábado', 'Treino livre', 'Foco em pontos fracos', '45 min', ''],
                    ['Domingo', 'Descanso', '-', '-', 'Recuperação']
